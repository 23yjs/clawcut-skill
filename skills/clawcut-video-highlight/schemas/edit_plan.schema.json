{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ClawCut Edit Plan",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "video_type",
    "highlight_definition",
    "chunks",
    "final_segments"
  ],
  "properties": {
    "video_type": {
      "type": "string",
      "minLength": 1
    },
    "highlight_definition": {
      "type": "object"
    },
    "chunks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "start",
          "end",
          "summary"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "start": {
            "type": "number",
            "minimum": 0
          },
          "end": {
            "type": "number",
            "minimum": 0
          },
          "summary": {
            "type": "string"
          },
          "highlight_score": {
            "type": "number"
          }
        },
        "additionalProperties": true
      }
    },
    "final_segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "start",
          "end",
          "reason"
        ],
        "properties": {
          "start": {
            "type": "number",
            "minimum": 0
          },
          "end": {
            "type": "number",
            "minimum": 0
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "source_chunk_id": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  }
}
